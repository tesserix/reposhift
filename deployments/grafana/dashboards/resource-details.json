{
  "dashboard": {
    "title": "ADO to GitHub Migration - Resource Details",
    "description": "Detailed metrics about migrated resources (repositories, work items, etc.)",
    "tags": ["ado-github-migration", "resources"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "1m",
    "panels": [
      {
        "id": 1,
        "title": "Total Repositories Migrated",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "sum(ado_github_migration_repositories_migrated_total)",
            "legendFormat": "Total Repos",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "blue", "value": null}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Total Work Items Migrated",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "sum(ado_github_migration_work_items_migrated_total)",
            "legendFormat": "Total Work Items",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "purple", "value": null}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Total Data Migrated",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum(ado_github_migration_repository_size_bytes_sum)",
            "legendFormat": "Total Size",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1073741824},
                {"color": "orange", "value": 10737418240}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Avg Commits per Repository",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "sum(ado_github_migration_repository_commits_sum) / sum(ado_github_migration_repository_commits_count)",
            "legendFormat": "Avg Commits",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "decimals": 0,
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "blue", "value": null}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Repository Size Distribution",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
        "targets": [
          {
            "expr": "sum by (le) (rate(ado_github_migration_repository_size_bytes_bucket[5m]))",
            "legendFormat": "{{le}}",
            "refId": "A",
            "format": "heatmap"
          }
        ],
        "options": {
          "calculate": false,
          "cellGap": 2,
          "color": {
            "exponent": 0.5,
            "fill": "dark-orange",
            "mode": "scheme",
            "scale": "exponential",
            "scheme": "Spectral",
            "steps": 128
          },
          "exemplars": {
            "color": "rgba(255,0,255,0.7)"
          },
          "filterValues": {
            "le": 1e-9
          },
          "legend": {
            "show": true
          },
          "rowsFrame": {
            "layout": "auto"
          },
          "tooltip": {
            "show": true,
            "yHistogram": true
          },
          "yAxis": {
            "axisPlacement": "left",
            "reverse": false,
            "unit": "bytes"
          }
        }
      },
      {
        "id": 6,
        "title": "Commits Distribution",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
        "targets": [
          {
            "expr": "sum by (le) (rate(ado_github_migration_repository_commits_bucket[5m]))",
            "legendFormat": "{{le}}",
            "refId": "A",
            "format": "heatmap"
          }
        ],
        "options": {
          "calculate": false,
          "cellGap": 2,
          "color": {
            "exponent": 0.5,
            "fill": "dark-blue",
            "mode": "scheme",
            "scale": "exponential",
            "scheme": "Blues",
            "steps": 64
          },
          "legend": {
            "show": true
          },
          "tooltip": {
            "show": true,
            "yHistogram": true
          },
          "yAxis": {
            "axisPlacement": "left",
            "reverse": false,
            "unit": "short"
          }
        }
      },
      {
        "id": 7,
        "title": "Repositories by Visibility",
        "type": "piechart",
        "gridPos": {"h": 8, "w": 8, "x": 0, "y": 14},
        "targets": [
          {
            "expr": "sum by (visibility) (ado_github_migration_repositories_migrated_total)",
            "legendFormat": "{{visibility}}",
            "refId": "A"
          }
        ],
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "values": ["value", "percent"]
          },
          "pieType": "donut"
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"}
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "private"},
              "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]
            },
            {
              "matcher": {"id": "byName", "options": "internal"},
              "properties": [{"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]
            },
            {
              "matcher": {"id": "byName", "options": "public"},
              "properties": [{"id": "color", "value": {"fixedColor": "green", "mode": "fixed"}}]
            }
          ]
        }
      },
      {
        "id": 8,
        "title": "Repositories by Organization",
        "type": "bargauge",
        "gridPos": {"h": 8, "w": 8, "x": 8, "y": 14},
        "targets": [
          {
            "expr": "topk(10, sum by (organization) (ado_github_migration_repositories_migrated_total))",
            "legendFormat": "{{organization}}",
            "refId": "A"
          }
        ],
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient",
          "showUnfilled": true
        },
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "continuous-BlYlRd"}
          }
        }
      },
      {
        "id": 9,
        "title": "Work Items by Type Mapping",
        "type": "table",
        "gridPos": {"h": 8, "w": 8, "x": 16, "y": 14},
        "targets": [
          {
            "expr": "sum by (source_type, target_type) (ado_github_migration_work_items_migrated_total)",
            "legendFormat": "",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [
            {
              "displayName": "Value",
              "desc": true
            }
          ]
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "auto",
              "displayMode": "auto"
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Value"},
              "properties": [
                {
                  "id": "custom.displayMode",
                  "value": "color-background"
                },
                {
                  "id": "custom.cellOptions",
                  "value": {
                    "type": "color-background"
                  }
                }
              ]
            }
          ]
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true
              },
              "renameByName": {
                "source_type": "ADO Type",
                "target_type": "GitHub Type",
                "Value": "Count"
              }
            }
          }
        ]
      },
      {
        "id": 10,
        "title": "Repository Branches Distribution",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(ado_github_migration_repository_branches_bucket[5m])))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.75, sum(rate(ado_github_migration_repository_branches_bucket[5m])))",
            "legendFormat": "p75",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.90, sum(rate(ado_github_migration_repository_branches_bucket[5m])))",
            "legendFormat": "p90",
            "refId": "C"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(ado_github_migration_repository_branches_bucket[5m])))",
            "legendFormat": "p95",
            "refId": "D"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(ado_github_migration_repository_branches_bucket[5m])))",
            "legendFormat": "p99",
            "refId": "E"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 0,
              "lineInterpolation": "smooth",
              "lineWidth": 2
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 11,
        "title": "Repository Tags Distribution",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
        "targets": [
          {
            "expr": "histogram_quantile(0.50, sum(rate(ado_github_migration_repository_tags_bucket[5m])))",
            "legendFormat": "p50",
            "refId": "A"
          },
          {
            "expr": "histogram_quantile(0.75, sum(rate(ado_github_migration_repository_tags_bucket[5m])))",
            "legendFormat": "p75",
            "refId": "B"
          },
          {
            "expr": "histogram_quantile(0.90, sum(rate(ado_github_migration_repository_tags_bucket[5m])))",
            "legendFormat": "p90",
            "refId": "C"
          },
          {
            "expr": "histogram_quantile(0.95, sum(rate(ado_github_migration_repository_tags_bucket[5m])))",
            "legendFormat": "p95",
            "refId": "D"
          },
          {
            "expr": "histogram_quantile(0.99, sum(rate(ado_github_migration_repository_tags_bucket[5m])))",
            "legendFormat": "p99",
            "refId": "E"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 0,
              "lineInterpolation": "smooth",
              "lineWidth": 2
            },
            "unit": "short"
          }
        }
      },
      {
        "id": 12,
        "title": "Work Item Complexity",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 30},
        "targets": [
          {
            "expr": "sum(ado_github_migration_work_item_comments_sum) / sum(ado_github_migration_work_item_comments_count)",
            "legendFormat": "Avg Comments per Item",
            "refId": "A"
          },
          {
            "expr": "sum(ado_github_migration_work_item_attachments_sum) / sum(ado_github_migration_work_item_attachments_count)",
            "legendFormat": "Avg Attachments per Item",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineInterpolation": "smooth",
              "lineWidth": 2
            },
            "decimals": 1
          }
        }
      },
      {
        "id": 13,
        "title": "Migration Throughput (Items/Hour)",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 30},
        "targets": [
          {
            "expr": "sum(rate(ado_github_migration_repositories_migrated_total[1h])) * 3600",
            "legendFormat": "Repositories/Hour",
            "refId": "A"
          },
          {
            "expr": "sum(rate(ado_github_migration_work_items_migrated_total[1h])) * 3600",
            "legendFormat": "Work Items/Hour",
            "refId": "B"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "axisPlacement": "auto",
              "drawStyle": "bars",
              "fillOpacity": 80,
              "lineWidth": 0
            },
            "decimals": 0
          }
        }
      }
    ]
  }
}
