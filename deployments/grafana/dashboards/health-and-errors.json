{
  "dashboard": {
    "title": "ADO to GitHub Migration - Health & Errors",
    "description": "System health, errors, rate limits, resource usage",
    "tags": ["ado-github-migration", "health", "errors"],
    "timezone": "browser",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "30s",
    "panels": [
      {
        "id": 1,
        "title": "Operator Health Status",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 0, "y": 0},
        "targets": [
          {
            "expr": "min(ado_github_migration_operator_health)",
            "legendFormat": "Health",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": {"text": "UNHEALTHY", "color": "red"},
                  "1": {"text": "HEALTHY", "color": "green"}
                }
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "red", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 2,
        "title": "Leader Election Status",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 6, "y": 0},
        "targets": [
          {
            "expr": "ado_github_migration_leader_election_status",
            "legendFormat": "Leader",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "background",
          "graphMode": "none",
          "textMode": "value_and_name"
        },
        "fieldConfig": {
          "defaults": {
            "mappings": [
              {
                "type": "value",
                "options": {
                  "0": {"text": "FOLLOWER", "color": "yellow"},
                  "1": {"text": "LEADER", "color": "green"}
                }
              }
            ],
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "yellow", "value": null},
                {"color": "green", "value": 1}
              ]
            }
          }
        }
      },
      {
        "id": 3,
        "title": "Error Rate",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 12, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(ado_github_migration_errors_total[5m]))",
            "legendFormat": "Errors/sec",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "decimals": 2,
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 0.1},
                {"color": "orange", "value": 1},
                {"color": "red", "value": 5}
              ]
            }
          }
        }
      },
      {
        "id": 4,
        "title": "Retry Rate",
        "type": "stat",
        "gridPos": {"h": 6, "w": 6, "x": 18, "y": 0},
        "targets": [
          {
            "expr": "sum(rate(ado_github_migration_retries_total[5m]))",
            "legendFormat": "Retries/sec",
            "refId": "A"
          }
        ],
        "options": {
          "colorMode": "value",
          "graphMode": "area"
        },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "decimals": 2,
            "color": {"mode": "thresholds"},
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {"color": "green", "value": null},
                {"color": "yellow", "value": 1},
                {"color": "orange", "value": 5},
                {"color": "red", "value": 10}
              ]
            }
          }
        }
      },
      {
        "id": 5,
        "title": "Component Health Status",
        "type": "table",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 6},
        "targets": [
          {
            "expr": "ado_github_migration_operator_health",
            "legendFormat": "",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [
            {
              "displayName": "Status",
              "desc": false
            }
          ]
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "auto",
              "displayMode": "auto"
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Value"},
              "properties": [
                {
                  "id": "custom.displayMode",
                  "value": "color-background"
                },
                {
                  "id": "mappings",
                  "value": [
                    {
                      "type": "value",
                      "options": {
                        "0": {"text": "UNHEALTHY", "color": "red"},
                        "1": {"text": "HEALTHY", "color": "green"}
                      }
                    }
                  ]
                }
              ]
            }
          ]
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "instance": true,
                "job": true
              },
              "renameByName": {
                "component": "Component",
                "Value": "Status"
              }
            }
          }
        ]
      },
      {
        "id": 6,
        "title": "API Rate Limit Remaining",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 6},
        "targets": [
          {
            "expr": "ado_github_migration_api_rate_limit_remaining",
            "legendFormat": "{{service}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineInterpolation": "smooth",
              "lineWidth": 2
            },
            "unit": "short"
          }
        },
        "options": {
          "legend": {
            "displayMode": "table",
            "placement": "right",
            "values": ["last", "min"]
          }
        },
        "alert": {
          "conditions": [
            {
              "evaluator": {
                "params": [100],
                "type": "lt"
              },
              "operator": {
                "type": "and"
              },
              "query": {
                "params": ["A", "5m", "now"]
              },
              "reducer": {
                "params": [],
                "type": "min"
              },
              "type": "query"
            }
          ],
          "name": "Low API Rate Limit",
          "message": "API rate limit is running low"
        }
      },
      {
        "id": 7,
        "title": "Errors by Type",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 14},
        "targets": [
          {
            "expr": "sum by (error_type) (rate(ado_github_migration_errors_total[5m]))",
            "legendFormat": "{{error_type}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineInterpolation": "smooth",
              "lineWidth": 2,
              "stacking": {
                "mode": "normal"
              }
            },
            "unit": "ops"
          },
          "overrides": [
            {
              "matcher": {"id": "byRegexp", "options": ".*retryable.*"},
              "properties": [{"id": "color", "value": {"fixedColor": "yellow", "mode": "fixed"}}]
            },
            {
              "matcher": {"id": "byRegexp", "options": ".*terminal.*"},
              "properties": [{"id": "color", "value": {"fixedColor": "red", "mode": "fixed"}}]
            },
            {
              "matcher": {"id": "byRegexp", "options": ".*validation.*"},
              "properties": [{"id": "color", "value": {"fixedColor": "orange", "mode": "fixed"}}]
            }
          ]
        }
      },
      {
        "id": 8,
        "title": "Errors by Controller",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 14},
        "targets": [
          {
            "expr": "sum by (controller) (rate(ado_github_migration_errors_total[5m]))",
            "legendFormat": "{{controller}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineInterpolation": "smooth",
              "lineWidth": 2
            },
            "unit": "ops"
          }
        }
      },
      {
        "id": 9,
        "title": "Retry Backoff Distribution",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 22},
        "targets": [
          {
            "expr": "sum by (le) (rate(ado_github_migration_retry_backoff_seconds_bucket[5m]))",
            "legendFormat": "{{le}}",
            "refId": "A",
            "format": "heatmap"
          }
        ],
        "options": {
          "calculate": false,
          "cellGap": 2,
          "color": {
            "exponent": 0.5,
            "fill": "dark-red",
            "mode": "scheme",
            "scale": "exponential",
            "scheme": "Reds",
            "steps": 64
          },
          "legend": {
            "show": true
          },
          "tooltip": {
            "show": true,
            "yHistogram": true
          },
          "yAxis": {
            "axisPlacement": "left",
            "reverse": false,
            "unit": "s"
          }
        },
        "description": "Distribution of retry backoff delays"
      },
      {
        "id": 10,
        "title": "Rate Limit Hits by Service",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 22},
        "targets": [
          {
            "expr": "sum by (service) (rate(ado_github_migration_rate_limit_hits_total[5m]))",
            "legendFormat": "{{service}}",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "axisPlacement": "auto",
              "drawStyle": "bars",
              "fillOpacity": 80,
              "lineWidth": 0
            },
            "unit": "ops"
          }
        },
        "description": "Rate at which we hit API rate limits"
      },
      {
        "id": 11,
        "title": "Memory Usage",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 0, "y": 30},
        "targets": [
          {
            "expr": "ado_github_migration_memory_usage_bytes{memory_type=\"alloc\"} / 1024 / 1024",
            "legendFormat": "Allocated (MB)",
            "refId": "A"
          },
          {
            "expr": "ado_github_migration_memory_usage_bytes{memory_type=\"sys\"} / 1024 / 1024",
            "legendFormat": "System (MB)",
            "refId": "B"
          },
          {
            "expr": "ado_github_migration_memory_usage_bytes{memory_type=\"heap\"} / 1024 / 1024",
            "legendFormat": "Heap (MB)",
            "refId": "C"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 10,
              "lineInterpolation": "smooth",
              "lineWidth": 2
            },
            "unit": "decmbytes"
          }
        }
      },
      {
        "id": 12,
        "title": "Goroutines",
        "type": "timeseries",
        "gridPos": {"h": 8, "w": 12, "x": 12, "y": 30},
        "targets": [
          {
            "expr": "ado_github_migration_goroutines_active",
            "legendFormat": "Active Goroutines",
            "refId": "A"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {"mode": "palette-classic"},
            "custom": {
              "axisPlacement": "auto",
              "drawStyle": "line",
              "fillOpacity": 20,
              "lineInterpolation": "smooth",
              "lineWidth": 2
            },
            "unit": "short"
          }
        },
        "description": "Number of active goroutines - watch for leaks"
      },
      {
        "id": 13,
        "title": "Build Information",
        "type": "table",
        "gridPos": {"h": 6, "w": 24, "x": 0, "y": 38},
        "targets": [
          {
            "expr": "ado_github_migration_build_info",
            "legendFormat": "",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "options": {
          "showHeader": true
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true,
                "__name__": true,
                "Value": true,
                "instance": true,
                "job": true
              },
              "renameByName": {
                "version": "Version",
                "git_commit": "Git Commit",
                "build_date": "Build Date",
                "go_version": "Go Version"
              }
            }
          }
        ]
      },
      {
        "id": 14,
        "title": "Error Rate by Phase",
        "type": "heatmap",
        "gridPos": {"h": 8, "w": 24, "x": 0, "y": 44},
        "targets": [
          {
            "expr": "sum by (phase) (rate(ado_github_migration_errors_total[5m]))",
            "legendFormat": "{{phase}}",
            "refId": "A",
            "format": "heatmap"
          }
        ],
        "options": {
          "calculate": false,
          "cellGap": 2,
          "color": {
            "exponent": 0.5,
            "fill": "dark-red",
            "mode": "scheme",
            "scale": "exponential",
            "scheme": "Oranges",
            "steps": 64
          },
          "legend": {
            "show": true
          },
          "tooltip": {
            "show": true,
            "yHistogram": false
          },
          "yAxis": {
            "axisPlacement": "left",
            "reverse": false
          }
        },
        "description": "Which phases are generating the most errors"
      },
      {
        "id": 15,
        "title": "Top 10 Error Messages",
        "type": "table",
        "gridPos": {"h": 10, "w": 24, "x": 0, "y": 52},
        "targets": [
          {
            "expr": "topk(10, sum by (error_message) (increase(ado_github_migration_errors_total[1h])))",
            "legendFormat": "",
            "refId": "A",
            "format": "table",
            "instant": true
          }
        ],
        "options": {
          "showHeader": true,
          "sortBy": [
            {
              "displayName": "Count (1h)",
              "desc": true
            }
          ]
        },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "align": "auto",
              "displayMode": "auto"
            }
          },
          "overrides": [
            {
              "matcher": {"id": "byName", "options": "Value"},
              "properties": [
                {
                  "id": "custom.displayMode",
                  "value": "color-background"
                },
                {
                  "id": "color",
                  "value": {
                    "mode": "continuous-RdYlGr"
                  }
                }
              ]
            }
          ]
        },
        "transformations": [
          {
            "id": "organize",
            "options": {
              "excludeByName": {
                "Time": true
              },
              "renameByName": {
                "error_message": "Error Message",
                "Value": "Count (1h)"
              }
            }
          }
        ]
      }
    ]
  }
}
